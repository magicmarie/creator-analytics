{
  "name": "creatorscope-backend",
  "version": "1.0.0",
  "description": "Multi-platform creator analytics API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "migrate": "node dist/db/migrations.js",
    "seed:tracked": "node dist/db/seed-tracked-creators.js",
    "seed:campaigns": "node dist/db/seed-campaigns.js",
    "migrate:dev": "ts-node src/db/migrations.ts",
    "seed:tracked:dev": "ts-node src/db/seed-tracked-creators.ts",
    "seed:campaigns:dev": "ts-node src/db/seed-campaigns.ts",
    "ingest": "ts-node src/ingestion/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "creator-analytics",
    "api",
    "typescript",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/node-cron": "^3.0.11",
    "axios": "^1.13.6",
    "bullmq": "^5.71.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ioredis": "^5.10.0",
    "node-cron": "^4.2.1",
    "opossum": "^9.0.0",
    "pg": "^8.11.3",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.10.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
