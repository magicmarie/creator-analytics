# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creatorscope

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Keys (Get your free keys)
# YouTube: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# GitHub: https://github.com/settings/tokens
YOUTUBE_API_KEY=your_youtube_api_key_here
GITHUB_TOKEN=your_github_token_here

# Server
PORT=4000
NODE_ENV=development

# Logging
LOG_LEVEL=debug

# Security
API_RATE_LIMIT=100
API_RATE_WINDOW_MS=900000

# Cache TTL (seconds)
CACHE_TTL_CREATORS=300
CACHE_TTL_ANALYTICS=600

# Ingestion
INGESTION_SCHEDULE=0 */12 * * *
